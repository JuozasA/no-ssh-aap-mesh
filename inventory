# This section is for your AAP Automation Metrics Service host(s)
# -----------------------------------------------------
[automationmetrics]
metrics.sandbox1920.opentlc.com

[automationhub]
hub-1.sandbox1920.opentlc.com

[automationgateway]
gw-1.sandbox1920.opentlc.com ansible_host=
gw-2.sandbox1920.opentlc.com ansible_host=

# This section is for your AAP Controller host(s)
# -----------------------------------------------------
[automationcontroller]
ctrl-1.sandbox1920.opentlc.com receptor_tls_cert=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/ctrl-1.sandbox1920.opentlc.com.crt receptor_tls_key=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/ctrl-1.sandbox1920.opentlc.com.key
ctrl-2.sandbox1920.opentlc.com receptor_tls_cert=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/ctrl-2.sandbox1920.opentlc.com.crt receptor_tls_key=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/ctrl-2.sandbox1920.opentlc.com.key

[automationcontroller:vars]
# receptor_peers (no underscore) — prevents installer auto-assigning exec node directly to controllers
receptor_peers=[]
# _receptor_peers (with underscore) — init.yml Jinja2 workaround guard for excluded node processing
_receptor_peers=[]

# This section is for your AAP Automation Hub host(s)
# -----------------------------------------------------

[execution_nodes]
hop-node.srbbx.azure.redhatworkshops.io receptor_peers=["ctrl-2.sandbox1920.opentlc.com","ctrl-1.sandbox1920.opentlc.com"] _receptor_hostname=hop-node.srbbx.azure.redhatworkshops.io _receptor_type=hop _system_uuid= receptor_tls_cert=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/hop-node.srbbx.azure.redhatworkshops.io.crt receptor_tls_key=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/hop-node.srbbx.azure.redhatworkshops.io.key
mesh-node.srbbx.azure.redhatworkshops.io receptor_peers=["hop-node.srbbx.azure.redhatworkshops.io"] _receptor_hostname=mesh-node.srbbx.azure.redhatworkshops.io _receptor_type=execution _system_uuid= receptor_tls_cert=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/mesh-node.srbbx.azure.redhatworkshops.io.crt receptor_tls_key=/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/mesh-node.srbbx.azure.redhatworkshops.io.key

[execution_nodes:vars]
# For SSH-accessible nodes this value is overridden at runtime by facts.yml set_fact.
_receptor_peers=[]
_receptor_protocol=tcp
_receptor_port=27199

[redis]
metrics.sandbox1920.opentlc.com

[all:vars]
# Common variables
# -----------------------------------------------------
postgresql_admin_username=postgres
postgresql_admin_password=
ansible_env='{"PGSSLMODE": "require", "PGSSLROOTCERT": "/dev/null"}'
bundle_install=true
# The bundle directory must include /bundle in the path
bundle_dir='{{ lookup("ansible.builtin.env", "PWD") }}/bundle'

controller_data_dir='/opt/aap/controller/data'

# Tell the installer to use SSL
pg_sslmode='verify-full'
# Tell the installer where the AWS cert is
custom_ca_cert='/home/ec2-user/ansible-automation-platform-containerized-setup-bundle-2.7-1.2-x86_64-rhel9/receptor-tls/custom-ca-bundle.pem'
redis_mode='standalone'

# AAP Gateway
# -----------------------------------------------------
gateway_admin_password=
gateway_pg_host=
gateway_pg_database=gw-db
gateway_pg_username=postgres-gw
gateway_pg_password=

# AAP Controller
# -----------------------------------------------------
controller_admin_password=
controller_pg_host=
controller_pg_database=ctrl-db
controller_pg_username=postgres-ctrl
controller_pg_password=

# AAP Automation Hub
# -----------------------------------------------------
hub_admin_password=
hub_pg_host=
hub_pg_database=hub-db
hub_pg_username=postgres-hub
hub_pg_password=

automationmetrics_pg_host=
automationmetrics_pg_database=metrics
automationmetrics_pg_username=metrics-user
automationmetrics_pg_password=
automationmetrics_controller_db=ctrl-db
automationmetrics_controller_read_pg_host=
automationmetrics_controller_read_pg_password=
