# Execution / hop nodes
# -----------------------------------------------------
# Installer command (excludes non-SSH groups):
#   ansible-playbook -i inventory ansible.containerized_installer.install \
#     --limit 'all:!onprem_execution_nodes:!azure_execution_nodes'
#
# Non-SSH nodes (on-prem, Azure) are installed via generate-exec-node-bundle.yml
# + install-exec-node.yml transferred and run on the node itself.

[execution_nodes:children]
aws_execution_nodes
onprem_execution_nodes
azure_execution_nodes

[execution_nodes:vars]
# Guard for excluded (non-SSH) nodes: init.yml on controllers iterates over ALL
# execution_nodes via hostvars and reads _receptor_peers. Excluded nodes never
# run facts.yml so _receptor_peers would be undefined → Jinja2 crash.
# For SSH-accessible nodes this value is overridden at runtime by facts.yml set_fact.
_receptor_peers=[]
_receptor_protocol=tcp
_receptor_port=27199

# ── AWS execution nodes (SSH accessible — installer configures directly) ──────
[aws_execution_nodes]
# For SSH-accessible nodes facts.yml runs on the node and populates the
# underscore-prefixed vars (_receptor_type, _system_uuid, _receptor_peers, …)
# at runtime, so only the NO-underscore input variables are needed here:
#
#   receptor_type   → use 'hop' for hop nodes; omit for execution (role default = 'execution')
#   receptor_peers  → computed automatically from topology; omit unless you need to override
#   _system_uuid    → discovered from ansible_product_uuid / ansible_machine_id; omit
#
# Example:
# aws-hop-1.eu-west-2.compute.internal  receptor_type=hop
# aws-exec-1.eu-west-2.compute.internal receptor_peers=["aws-hop-1.eu-west-2.compute.internal"] 

# ── On-prem execution nodes (no SSH — use generate-exec-node-bundle.yml) ─────
[onprem_execution_nodes]
ip-11-0-133-15.eu-west-2.compute.internal receptor_peers=["ip-10-0-131-147.eu-west-2.compute.internal","ip-10-0-137-147.eu-west-2.compute.internal"] _receptor_hostname=ip-11-0-133-15.eu-west-2.compute.internal _receptor_type=hop _system_uuid=ec2a2b88-a646-74b8-3053-e58334b2
ip-11-0-159-96.eu-west-2.compute.internal receptor_peers=["ip-11-0-133-15.eu-west-2.compute.internal"] _receptor_hostname=ip-11-0-159-96.eu-west-2.compute.internal _receptor_type=execution _system_uuid=ec2824db-c7ab-bcde-b3a1-ca775cd

# ── Azure execution nodes (no SSH — use generate-exec-node-bundle.yml) ───────
[azure_execution_nodes]
# Add Azure nodes here.
# Example:
# azure-hop-1.azure.internal receptor_peers=["ip-10-0-131-147.eu-west-2.compute.internal","ip-10-0-137-147.eu-west-2.compute.internal"] _receptor_hostname=azure-hop-1.azure.internal _receptor_type=hop _system_uuid=<uuid>
# azure-exec-1.azure.internal receptor_peers=["azure-hop-1.azure.internal"] _receptor_hostname=azure-exec-1.azure.internal _receptor_type=execution _system_uuid=<uuid>

